#!/usr/bin/env bash
set -euo pipefail

# ─── CutClub Dev Script ──────────────────────────────────────────────
# Uso: ./cb <comando> [servicio]
# ─────────────────────────────────────────────────────────────────────

PROJECT_DIR="$(cd "$(dirname "$0")" && pwd)"
API_DIR="$PROJECT_DIR/api"
APP_DIR="$PROJECT_DIR/app"

DB_CONTAINER="cutclub-postgres"
DB_NAME="cutclub"
DB_USER="cutclub"
DB_PASS="cutclub"
DB_PORT=5432

BACK_PID_FILE="/tmp/cutclub-back.pid"
FRONT_PID_FILE="/tmp/cutclub-front.pid"
BACK_LOG_FILE="$PROJECT_DIR/logs/backend.log"
FRONT_LOG_FILE="$PROJECT_DIR/logs/frontend.log"

# ─── Colores ─────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
BLUE='\033[0;34m'
CYAN='\033[0;36m'
NC='\033[0m'

info()    { echo -e "${BLUE}[info]${NC} $1"; }
success() { echo -e "${GREEN}[ok]${NC} $1"; }
warn()    { echo -e "${YELLOW}[warn]${NC} $1"; }
error()   { echo -e "${RED}[error]${NC} $1"; }

# ─── Funciones de estado ─────────────────────────────────────────────
is_db_running() {
  docker ps --format '{{.Names}}' 2>/dev/null | grep -q "^${DB_CONTAINER}$"
}

is_back_running() {
  [[ -f "$BACK_PID_FILE" ]] && kill -0 "$(cat "$BACK_PID_FILE")" 2>/dev/null
}

is_front_running() {
  [[ -f "$FRONT_PID_FILE" ]] && kill -0 "$(cat "$FRONT_PID_FILE")" 2>/dev/null
}

# ─── Base de datos ───────────────────────────────────────────────────
start_db() {
  if is_db_running; then
    warn "PostgreSQL ya está corriendo"
    return
  fi

  info "Iniciando PostgreSQL en Docker..."

  if docker ps -a --format '{{.Names}}' | grep -q "^${DB_CONTAINER}$"; then
    docker start "$DB_CONTAINER" > /dev/null
  else
    docker run -d \
      --name "$DB_CONTAINER" \
      -e POSTGRES_DB="$DB_NAME" \
      -e POSTGRES_USER="$DB_USER" \
      -e POSTGRES_PASSWORD="$DB_PASS" \
      -p "${DB_PORT}:5432" \
      postgres:17-alpine > /dev/null
  fi

  local retries=0
  while ! docker exec "$DB_CONTAINER" pg_isready -U "$DB_USER" -q 2>/dev/null; do
    retries=$((retries + 1))
    if [[ $retries -ge 30 ]]; then
      error "PostgreSQL no respondió a tiempo"
      exit 1
    fi
    sleep 1
  done

  success "PostgreSQL listo en localhost:${DB_PORT}"
}

stop_db() {
  if is_db_running; then
    info "Deteniendo PostgreSQL..."
    docker stop "$DB_CONTAINER" > /dev/null
    success "PostgreSQL detenido"
  else
    warn "PostgreSQL no está corriendo"
  fi
}

# ─── Backend ─────────────────────────────────────────────────────────
start_back() {
  if is_back_running; then
    warn "Backend ya está corriendo (PID $(cat "$BACK_PID_FILE"))"
    return
  fi

  info "Iniciando backend Spring Boot..."
  mkdir -p "$PROJECT_DIR/logs"
  cd "$API_DIR"
  nohup ./mvnw spring-boot:run \
    -Dspring-boot.run.arguments="--spring.datasource.username=$DB_USER --spring.datasource.password=$DB_PASS" \
    > "$BACK_LOG_FILE" 2>&1 &
  echo $! > "$BACK_PID_FILE"
  cd "$PROJECT_DIR"

  info "Esperando al backend..."
  local retries=0
  while true; do
    local http_code
    http_code=$(curl -s -o /dev/null -w "%{http_code}" http://localhost:8080/ 2>/dev/null || echo "000")
    if [[ "$http_code" != "000" ]]; then
      break
    fi
    retries=$((retries + 1))
    if [[ $retries -ge 60 ]]; then
      warn "Backend aún no responde — revisá con: ./cb log back"
      return
    fi
    if ! is_back_running; then
      error "El proceso del backend se detuvo. Revisá: ./cb log back"
      return
    fi
    sleep 2
  done

  success "Backend corriendo en http://localhost:8080"
}

stop_back() {
  if is_back_running; then
    local pid
    pid=$(cat "$BACK_PID_FILE")
    info "Deteniendo backend (PID $pid)..."
    kill "$pid" 2>/dev/null || true
    sleep 1
  fi
  rm -f "$BACK_PID_FILE"

  # Limpiar cualquier proceso colgado en el puerto 8080
  local port_pid
  port_pid=$(lsof -ti:8080 2>/dev/null || true)
  if [[ -n "$port_pid" ]]; then
    kill -9 $port_pid 2>/dev/null || true
    sleep 1
  fi

  pkill -9 -f "spring-boot:run" 2>/dev/null || true
  success "Backend detenido"
}

# ─── Frontend ────────────────────────────────────────────────────────
start_front() {
  if is_front_running; then
    warn "Frontend ya está corriendo (PID $(cat "$FRONT_PID_FILE"))"
    return
  fi

  info "Iniciando frontend Expo..."
  mkdir -p "$PROJECT_DIR/logs"
  cd "$APP_DIR"
  nohup npx expo start --web --port 8081 > "$FRONT_LOG_FILE" 2>&1 &
  echo $! > "$FRONT_PID_FILE"
  cd "$PROJECT_DIR"

  sleep 3
  success "Frontend corriendo en http://localhost:8081"
}

stop_front() {
  if is_front_running; then
    local pid
    pid=$(cat "$FRONT_PID_FILE")
    info "Deteniendo frontend (PID $pid)..."
    kill "$pid" 2>/dev/null || true
    sleep 1
  fi
  rm -f "$FRONT_PID_FILE"

  local port_pid
  port_pid=$(lsof -ti:8081 2>/dev/null || true)
  if [[ -n "$port_pid" ]]; then
    kill -9 $port_pid 2>/dev/null || true
  fi

  success "Frontend detenido"
}

# ─── Logs (tail -f sobre archivos de log) ────────────────────────────
cmd_log() {
  local service="${1:-}"
  case "$service" in
    back)
      if [[ ! -f "$BACK_LOG_FILE" ]]; then
        error "No se encontró el archivo de logs del backend"
        info "¿El backend está corriendo? Usá './cb start' para iniciarlo"
        exit 1
      fi
      info "Mostrando logs del backend (Ctrl+C para salir)..."
      tail -f -n +1 "$BACK_LOG_FILE"
      ;;
    front)
      if [[ ! -f "$FRONT_LOG_FILE" ]]; then
        error "No se encontró el archivo de logs del frontend"
        info "¿El frontend está corriendo? Usá './cb start' para iniciarlo"
        exit 1
      fi
      info "Mostrando logs del frontend (Ctrl+C para salir)..."
      tail -f -n +1 "$FRONT_LOG_FILE"
      ;;
    db)
      if ! is_db_running; then
        error "PostgreSQL no está corriendo"
        exit 1
      fi
      info "Mostrando logs de PostgreSQL (Ctrl+C para salir)..."
      docker logs -f "$DB_CONTAINER"
      ;;
    *)
      if [[ -z "$service" ]]; then
        error "Especificá el servicio: ./cb log <back|front|db>"
      else
        error "Servicio desconocido: $service (opciones: back, front, db)"
      fi
      exit 1
      ;;
  esac
}

# ─── Comandos compuestos ─────────────────────────────────────────────
cmd_start() {
  echo ""
  echo -e "${CYAN}═══════════════════════════════════════${NC}"
  echo -e "${CYAN}        CutClub — Iniciando stack      ${NC}"
  echo -e "${CYAN}═══════════════════════════════════════${NC}"
  echo ""

  start_db
  start_back
  start_front

  echo ""
  echo -e "${CYAN}═══════════════════════════════════════${NC}"
  echo -e "${GREEN}  Stack listo${NC}"
  echo -e "${CYAN}───────────────────────────────────────${NC}"
  echo -e "  DB:       ${YELLOW}localhost:${DB_PORT}${NC} (${DB_NAME})"
  echo -e "  Backend:  ${YELLOW}http://localhost:8080${NC}"
  echo -e "  Frontend: ${YELLOW}http://localhost:8081${NC}"
  echo -e "${CYAN}═══════════════════════════════════════${NC}"
  echo ""
}

cmd_stop() {
  echo ""
  info "Deteniendo todo el stack..."
  stop_front
  stop_back
  stop_db
  echo ""
  success "Stack detenido completamente"
}

cmd_restart() {
  cmd_stop
  echo ""
  cmd_start
}

cmd_status() {
  echo ""
  echo -e "${CYAN}Estado del stack:${NC}"

  if is_db_running; then
    echo -e "  DB:       ${GREEN}● corriendo${NC} (container: $DB_CONTAINER)"
  else
    echo -e "  DB:       ${RED}○ detenido${NC}"
  fi

  if is_back_running; then
    echo -e "  Backend:  ${GREEN}● corriendo${NC} (PID $(cat "$BACK_PID_FILE"))"
  else
    echo -e "  Backend:  ${RED}○ detenido${NC}"
  fi

  if is_front_running; then
    echo -e "  Frontend: ${GREEN}● corriendo${NC} (PID $(cat "$FRONT_PID_FILE"))"
  else
    echo -e "  Frontend: ${RED}○ detenido${NC}"
  fi
  echo ""
}

# ─── Ayuda ───────────────────────────────────────────────────────────
cmd_help() {
  echo ""
  echo -e "${CYAN}CutClub Dev CLI${NC}"
  echo ""
  echo "Uso: ./cb <comando> [servicio]"
  echo ""
  echo "Comandos principales:"
  echo "  start           Inicia DB + Backend + Frontend"
  echo "  stop            Detiene todo el stack"
  echo "  restart         Reinicia todo el stack"
  echo "  status          Muestra el estado de cada servicio"
  echo ""
  echo "Servicios individuales:"
  echo "  start:db        Inicia solo PostgreSQL"
  echo "  start:back      Inicia solo el backend"
  echo "  start:front     Inicia solo el frontend"
  echo "  stop:db         Detiene solo PostgreSQL"
  echo "  stop:back       Detiene solo el backend"
  echo "  stop:front      Detiene solo el frontend"
  echo ""
  echo "Logs (streaming en tiempo real):"
  echo "  log back        Logs del backend"
  echo "  log front       Logs del frontend"
  echo "  log db          Logs de PostgreSQL"
  echo ""
}

# ─── Router ──────────────────────────────────────────────────────────
case "${1:-help}" in
  start)        cmd_start ;;
  stop)         cmd_stop ;;
  restart)      cmd_restart ;;
  status)       cmd_status ;;

  start:db)     start_db ;;
  start:back)   start_back ;;
  start:front)  start_front ;;
  stop:db)      stop_db ;;
  stop:back)    stop_back ;;
  stop:front)   stop_front ;;

  log)          cmd_log "${2:-}" ;;

  help|--help|-h) cmd_help ;;
  *)
    error "Comando desconocido: $1"
    cmd_help
    exit 1
    ;;
esac
